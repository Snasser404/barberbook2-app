generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      String   @default("CUSTOMER") // CUSTOMER, BARBER, STAFF, ADMIN
  avatar    String?
  createdAt DateTime @default(now())

  // Email verification
  emailVerified            Boolean   @default(false)
  emailVerificationCode    String?
  emailVerificationExpires DateTime?

  // Password reset
  passwordResetToken   String?
  passwordResetCode    String?   // 6-digit code sent by email
  passwordResetExpires DateTime?

  // Soft-delete: when non-null, the account is suspended.
  // Set by admin; restorable from admin dashboard.
  deletedAt DateTime?

  // Super admin — owns the platform, cannot be demoted or deleted by other admins
  isSuperAdmin Boolean @default(false)

  supportTickets  SupportTicket[]
  auditLogActions AuditLog[]

  shop            BarberShop?
  staffProfile    Staff?
  appointments    Appointment[]
  reviews         Review[]
  favorites       Favorite[]
  staffReviews    StaffReview[]
  photos          CustomerPhoto[]
  staffFavorites  StaffFavorite[]
}

model BarberShop {
  id          String   @id @default(cuid())
  ownerId     String   @unique
  owner       User     @relation(fields: [ownerId], references: [id])
  name        String
  address     String
  description String?
  phone       String?
  openingTime String   @default("09:00")
  closingTime String   @default("18:00")
  coverImage  String?
  logo        String?
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  latitude    Float?
  longitude   Float?
  createdAt   DateTime @default(now())

  // Verification — new shops start PENDING and are hidden from public list
  // until an admin reviews their uploaded documents.
  verificationStatus String    @default("PENDING") // PENDING, VERIFIED, REJECTED
  verificationNotes  String?
  verifiedAt         DateTime?
  verifiedBy         String?   // admin userId

  images           ShopImage[]
  services         Service[]
  offers           Offer[]
  appointments     Appointment[]
  reviews          Review[]
  favorites        Favorite[]
  staff            Staff[]
  verificationDocs ShopVerificationDocument[]
}

model ShopVerificationDocument {
  id           String     @id @default(cuid())
  shopId       String
  shop         BarberShop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  url          String
  documentType String     @default("OTHER") // BUSINESS_LICENSE, ID, UTILITY_BILL, OTHER
  caption      String?
  createdAt    DateTime   @default(now())
}

// Append-only log of admin actions for accountability + customer support context.
model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  actor        User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorEmail   String?  // captured at write-time in case actor is deleted
  action       String   // e.g. USER_SUSPENDED, SHOP_VERIFIED, REVIEW_DELETED
  targetType   String?  // USER, SHOP, REVIEW, STAFF, OFFER, SERVICE, APPOINTMENT
  targetId     String?
  metadata     String?  // JSON-encoded extra context (reason text, before/after, etc.)
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([action])
}

// Support tickets — used by suspended users or anyone needing help.
model SupportTicket {
  id         String   @id @default(cuid())
  userId     String?  // null if the sender isn't logged in
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email      String   // contact email captured on the form
  name       String   // sender's name
  subject    String?
  message    String
  status     String   @default("OPEN") // OPEN, IN_PROGRESS, CLOSED
  adminReply String?
  repliedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status, createdAt])
}

model Staff {
  id          String      @id @default(cuid())
  shopId      String?
  shop        BarberShop? @relation(fields: [shopId], references: [id], onDelete: SetNull)
  userId      String?     @unique
  user        User?       @relation(fields: [userId], references: [id])
  name        String
  bio         String?
  avatar      String?
  specialties String?    // comma-separated tags e.g. "Fades,Beards,Hot shaves"
  rating      Float      @default(0)
  reviewCount Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  appointments Appointment[]
  reviews      StaffReview[]
  portfolio    StaffPortfolioPhoto[]
  favoritedBy  StaffFavorite[]
}

model StaffPortfolioPhoto {
  id        String   @id @default(cuid())
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  createdAt DateTime @default(now())
}

model StaffFavorite {
  id         String  @id @default(cuid())
  customerId String
  customer   User    @relation(fields: [customerId], references: [id])
  staffId    String
  staff      Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([customerId, staffId])
}

model StaffReview {
  id         String   @id @default(cuid())
  customerId String
  customer   User     @relation(fields: [customerId], references: [id])
  staffId    String
  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([customerId, staffId])
}

model ShopImage {
  id        String     @id @default(cuid())
  shopId    String
  shop      BarberShop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  createdAt DateTime   @default(now())
}

model Service {
  id          String     @id @default(cuid())
  shopId      String
  shop        BarberShop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  duration    Int
  isActive    Boolean    @default(true)

  appointments Appointment[]
  offers       Offer[]
}

model Offer {
  id              String     @id @default(cuid())
  shopId          String
  shop            BarberShop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  serviceId       String?
  service         Service?   @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  title           String
  description     String?
  discountPercent Int
  validUntil      DateTime?
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
}

model Appointment {
  id         String   @id @default(cuid())
  customerId String
  customer   User     @relation(fields: [customerId], references: [id])
  shopId     String
  shop       BarberShop @relation(fields: [shopId], references: [id])
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id])
  staffId    String?
  staff      Staff?   @relation(fields: [staffId], references: [id])
  date       String
  time       String
  status     String   @default("PENDING")
  notes      String?
  createdAt  DateTime @default(now())

  photos     CustomerPhoto[]
}

model CustomerPhoto {
  id            String       @id @default(cuid())
  customerId    String
  customer      User         @relation(fields: [customerId], references: [id])
  url           String
  caption       String?
  type          String       @default("INSPIRATION") // INSPIRATION or COMPLETED
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
}

model Review {
  id         String     @id @default(cuid())
  customerId String
  customer   User       @relation(fields: [customerId], references: [id])
  shopId     String
  shop       BarberShop @relation(fields: [shopId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime   @default(now())

  @@unique([customerId, shopId])
}

model Favorite {
  id         String     @id @default(cuid())
  customerId String
  customer   User       @relation(fields: [customerId], references: [id])
  shopId     String
  shop       BarberShop @relation(fields: [shopId], references: [id])

  @@unique([customerId, shopId])
}
